<article class="building-card">
  <a
    class="building-card__image-link"
    href="/commercial-real-estate/{{ building.state_abbr | lower }}/{{ building.city_slug | lower }}/buildings/{{ building.building_slug }}/"
    aria-label="View {{ building.name or building.address }}"
  >
    <img
      class="building-card__image"
      src="{{ building.hero_image or '/images/placeholders/building-placeholder.svg' }}"
      alt="{{ building.name or building.address }}"
      loading="lazy"
    />
  </a>

  <div class="building-card__body">
    <h3 class="building-card__title">
      <a href="/commercial-real-estate/{{ building.state_abbr | lower }}/{{ building.city_slug | lower }}/buildings/{{ building.building_slug }}/">
        {{ building.name or building.address }}
      </a>
    </h3>

    {% if building.address %}
      <p class="building-card__address">{{ building.address }}</p>
    {% endif %}

    <p class="building-card__meta">
      {{ building.type or "Commercial" }}
      {% if building.size %} • {{ building.size }}{% endif %}
    </p>

    {% if building.teaser %}
      <p class="building-card__teaser">{{ building.teaser }}</p>
    {% endif %}

    <p class="building-card__cta">
      <a href="/commercial-real-estate/{{ building.state_abbr | lower }}/{{ building.city_slug | lower }}/buildings/{{ building.building_slug }}/">
        View Building →
      </a>
    </p>
  </div>
</article>