{% set placeholderSrc = building | buildingPlaceholder %}
{% set buildingPath = "/commercial-real-estate/building/" + building.state_abbr + "/" + building.city_slug + "/" + building.building_slug + ".html" %}

<article class="building-card">
  <a
    class="building-card__image-link"
    href="{{ building.legacy_rofo_path }}"
    aria-label="View {{ building.name or building.address }}"
  >
    <img
      class="building-card__image"
      src="{{ building.hero_image or placeholderSrc }}"
      alt="{{ building.name or building.address }}"
      loading="lazy"
      decoding="async"
    />
  </a>

  <div class="building-card__body">
  {% if building.type %}
    <p class="building-card__eyebrow">{{ building.type }}</p>
  {% endif %}

  <h3 class="building-card__title">
    <a href="{{ building.legacy_rofo_path }}">
      {{ building.name or building.address }}
    </a>
  </h3>

    {% if building.address and building.name and building.address != building.name %}
  <p class="building-card__address">{{ building.address }}</p>
{% endif %}

    {% if building.size %}
  <p class="building-card__meta">
    {{ building.size }}
  </p>
{% endif %}

    <p class="building-card__cta">
      <a href="{{ building.legacy_rofo_path }}">
        View Building →
      </a>
    </p>
  </div>
</article>