{% set placeholderSrc = building | buildingPlaceholder %}
{% set buildingPath = building.building_path %}
{% set buildingTitle = building.address or building.name %}

<article class="building-card">

  <div class="building-card__media">
    <a
      href="{{ buildingPath }}"
      aria-label="View {{ buildingTitle }}"
    >
      <img
        class="building-card__image"
        src="{{ building.hero_image or placeholderSrc }}"
        alt="{{ buildingTitle }}"
        loading="lazy"
        decoding="async"
      />
    </a>

    <div class="building-card__overlay">
      <h3 class="building-card__title">
        <a href="{{ buildingPath }}">
          {{ buildingTitle }}
        </a>
      </h3>

      {% if building.type or building.size_label %}
        <p class="building-card__meta">
          {% if building.type %}{{ building.type }}{% endif %}
          {% if building.type and building.size_label %} • {% endif %}
          {% if building.size_label %}{{ building.size_label }}{% endif %}
        </p>
      {% endif %}

      {% if building.featured_company_name and building.featured_company_slug %}
  <p class="building-presented-by">
    Presented by
    <a href="/commercial-real-estate/company/{{ building.featured_company_slug }}/">
      {{ building.featured_company_name }}
    </a>
  </p>
{% endif %}
    </div>
  </div>

</article>