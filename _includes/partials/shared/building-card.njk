{% set placeholderSrc = building | buildingPlaceholder %}
{% set buildingPath = building.building_path %}

<article class="building-card">
  <a
    class="building-card__image-link"
    href="{{ buildingPath }}"
    aria-label="View {{ building.address or building.name }}"
  >
    <img
      class="building-card__image"
      src="{{ building.hero_image or placeholderSrc }}"
      alt="{{ building.address or building.name }}"
      loading="lazy"
      decoding="async"
    />
  </a>

  <div class="building-card__body">
    <h3 class="building-card__title">
      <a href="{{ buildingPath }}">
        {{ building.address or building.name }}
      </a>
    </h3>


    <div class="building-card__pill-row">
      {% if building.type %}
        <span class="building-card__pill">{{ building.type }}</span>
      {% endif %}
      {% if building.size_label %}
        <span class="building-card__pill">{{ building.size_label }}</span>
      {% endif %}
      <span class="building-card__pill">{{ building.city }}, {{ building.state_abbr }}</span>
    </div>

    <p class="building-card__cta">
      <a href="{{ buildingPath }}">
        View Building →
      </a>
    </p>
  </div>
</article>