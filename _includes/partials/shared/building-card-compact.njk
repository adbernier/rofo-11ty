{% set placeholderSrc = building | buildingPlaceholder %}
{% set buildingPath = "/commercial-real-estate/building/" + building.state_abbr + "/" + building.city_slug + "/" + building.building_slug + ".html" %}

<article class="building-card-compact">
  <a
    class="building-card-compact__image-link"
    href="{{ building.legacy_rofo_path }}"
    aria-label="View {{ building.name or building.address }}"
  >
    <img
      class="building-card-compact__image"
      src="{{ building.hero_image or placeholderSrc }}"
      alt="{{ building.name or building.address }}"
      loading="lazy"
      decoding="async"
    />
  </a>

  <div class="building-card-compact__content">
  {% if building.type %}
    <p class="building-card-compact__eyebrow">{{ building.type }}</p>
  {% endif %}

  <h3 class="building-card-compact__title">
    <a href="{{ building.legacy_rofo_path }}">
      {{ building.address or building.name }}
    </a>
  </h3>

    {% if building.size %}
  <p class="building-card-compact__meta">
    {{ building.size }}
  </p>
{% endif %}

    {% if building.address and building.name and building.address != building.name %}
  <p class="building-card-compact__address">{{ building.address }}</p>
{% endif %}
  </div>

  <p class="building-card-compact__cta">
    <a href="{{ building.legacy_rofo_path }}">
      View Building →
    </a>
  </p>
</article>