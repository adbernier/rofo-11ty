{% set placeholderSrc = building | buildingPlaceholder %}
{% set buildingPath = "/commercial-real-estate/building/" + building.state_abbr + "/" + building.city_slug + "/" + building.building_slug + ".html" %}

<article class="building-card-compact">
  <a
    class="building-card-compact__image-link"
    href="{{ buildingPath }}"
    aria-label="View {{ building.address or building.name }}"
  >
    <img
      class="building-card-compact__image"
      src="{{ building.hero_image or placeholderSrc }}"
      alt="{{ building.address or building.name }}"
      loading="lazy"
      decoding="async"
    />
  </a>

  <div class="building-card-compact__content">
    <h3 class="building-card-compact__title">
      <a href="{{ buildingPath }}">
        {{ building.address or building.name }}
      </a>
    </h3>


    <div class="building-card-compact__pill-row">
      {% if building.type %}
        <span class="building-card-compact__pill">{{ building.type }}</span>
      {% endif %}
      {% if building.size_label %}
        <span class="building-card-compact__pill">{{ building.size_label }}</span>
      {% endif %}
      <span class="building-card-compact__pill">{{ building.city }}, {{ building.state_abbr }}</span>
    </div>
  </div>

  <p class="building-card-compact__cta">
    <a href="{{ buildingPath }}">
      View Building →
    </a>
  </p>
</article>