{% set allTypes = [
  { "slug": "office-space", "label": "Office" },
  { "slug": "retail-space", "label": "Retail" },
  { "slug": "industrial-space", "label": "Industrial" },
  { "slug": "flex-space", "label": "Flex" },
  { "slug": "coworking-space", "label": "Coworking" }
] %}

{% set activeSlug = "" %}
{% if spaceType and spaceType.slug %}
  {% set activeSlug = spaceType.slug %}
{% endif %}

<div class="pill-nav">
  {% for item in allTypes %}
    <a
      class="pill{% if item.slug == activeSlug %} is-active{% endif %}"
      href="/commercial-real-estate/{{ city.state_abbr | lower }}/{{ city.slug | lower }}/{{ item.slug }}/"
      {% if item.slug == activeSlug %}aria-current="page"{% endif %}
    >
      {{ item.label }}
    </a>
  {% endfor %}

  {% if city.county %}
    <span class="pill pill--muted">{{ city.county }}</span>
  {% endif %}
</div>