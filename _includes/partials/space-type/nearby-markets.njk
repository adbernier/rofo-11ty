<div class="city-card">
  <div class="eyebrow">Nearby Markets</div>
  <h2>Compare nearby markets</h2>

  {% if city.nearby_city_details and city.nearby_city_details.length %}
    <div class="market-links">
      {% for nearby in city.nearby_city_details.slice(0, 6) %}
        <a href="/commercial-real-estate/{{ nearby.state_abbr | lower }}/{{ nearby.slug | lower }}/{{ spaceType.slug }}/">
          {{ nearby.city }}, {{ nearby.state_abbr }}
          {% if nearby.distance_miles %} {{ nearby.distance_miles }} miles away{% endif %}
        </a>
      {% endfor %}
    </div>
  {% else %}
    <p>Browse nearby markets to compare options in the region.</p>
  {% endif %}
</div>