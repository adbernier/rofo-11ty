<div class="city-card">
  <div class="eyebrow">Nearby Markets</div>
  <h2>Explore nearby markets</h2>
  <p>Businesses often consider these nearby markets when evaluating {{ spaceType.label | lower }} options in {{ city.city }}.</p>

  {% if city.nearby_cities and city.nearby_cities.length %}
    <div class="market-links">
      {% for nearby in city.nearby_cities %}
        <a href="{{ nearby.path }}{{ spaceType.slug }}/">
          {{ nearby.city }}, {{ nearby.state_abbr }}
        </a>
      {% endfor %}
    </div>
  {% else %}
    <p>Browse nearby markets to compare options in the region.</p>
  {% endif %}
</div>