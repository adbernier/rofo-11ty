<header class="topbar">
  <div class="container nav-wrap">
    <a class="logo" href="/">
      <img src="/images/logo/RofoLogo.png" alt="Rofo" />
    </a>

    <nav class="nav">
      <a href="/">Home</a>
      <a href="/markets/">Markets</a>
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a href="/#contact">Contact</a>
    </nav>

    <button class="mobile-menu-toggle" type="button" aria-label="Open menu" onclick="document.body.classList.toggle('mobile-menu-open')">
      ☰
    </button>

    <div class="nav-search" data-market-search>
      <label class="sr-only" for="headerMarketSearch">Search markets</label>
      <input
        id="headerMarketSearch"
        class="nav-search__input"
        type="text"
        placeholder="Search city or market"
        autocomplete="off"
      />
      <div class="search-results" id="headerMarketResults"></div>
    </div>

    <div class="actions">
      <a class="btn btn-secondary" href="/markets/">Browse Markets</a>
      <a class="btn btn-secondary" href="/#contact">Get Help</a>
    </div>
  </div>

  <div class="mobile-menu">
    <div class="container mobile-menu__inner">
      <a href="/">Home</a>
      <a href="/markets/">Markets</a>
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a href="/#contact">Contact</a>
    </div>
  </div>
</header>