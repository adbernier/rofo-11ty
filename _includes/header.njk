<header class="topbar">
  <div class="container nav-wrap">
    <a class="logo" href="/">
      <span class="logo-badge">R</span>
      <span>Rofo</span>
    </a>

    <nav class="nav">
      <a href="/">Home</a>
      <a href="/#markets">Markets</a>
      <a href="/#contact">Contact</a>
    </nav>

    <div class="nav-search" data-market-search>
      <label class="sr-only" for="headerMarketSearch">Search markets</label>
      <input
        id="headerMarketSearch"
        class="nav-search__input"
        type="text"
        placeholder="Search city or market"
        autocomplete="off"
      />
      <div class="search-results" id="headerMarketResults"></div>
    </div>

    <div class="actions">
      <a class="btn btn-secondary" href="/#markets">Browse Markets</a>
      <a class="btn btn-primary" href="/#contact">Get Help</a>
    </div>
  </div>
</header>
