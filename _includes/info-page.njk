---
layout: base.njk
---

<style>
  .info-page {
    padding: 8px 0 56px;
  }

  .info-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .info-card {
    background: #fff;
    border: 1px solid #d8e0ea;
    border-radius: 18px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    padding: 28px;
  }

  .info-pill {
    display: inline-flex;
    align-items: center;
    padding: 9px 14px;
    border-radius: 999px;
    background: #e9eefb;
    color: #1346d8;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }

  .info-header {
    max-width: 1000px;
    margin-bottom: 20px;
  }

  .info-page h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.08;
    margin: 0 0 14px;
    color: #0f172a;
    max-width: 22ch;
  }

  .info-dek {
    font-size: 1.05rem;
    line-height: 1.65;
    color: #475569;
    margin: 0;
    max-width: 70ch;
  }

  .info-body {
    max-width: 760px;
    color: #334155;
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .info-body h2 {
    font-size: 1.6rem;
    line-height: 1.2;
    margin: 32px 0 12px;
    color: #0f172a;
  }

  .info-body h3 {
    font-size: 1.2rem;
    line-height: 1.3;
    margin: 24px 0 10px;
    color: #0f172a;
  }

  .info-body p {
    margin: 0 0 16px;
  }

  .info-body ul,
  .info-body ol {
    margin: 0 0 18px 22px;
    padding: 0;
  }

  .info-body li {
    margin: 0 0 8px;
  }

  .info-body a {
    color: #1346d8;
    text-decoration: none;
    font-weight: 600;
  }

  .info-body a:hover {
    text-decoration: underline;
  }

  .info-body strong {
    color: #0f172a;
  }

  @media (max-width: 680px) {
    .info-shell {
      padding: 0 16px;
    }

    .info-card {
      padding: 22px;
    }

    .info-header,
    .info-body {
      max-width: none;
    }

    .info-page h1 {
      max-width: none;
    }
  }
</style>

<section class="info-page">
  <div class="info-shell">
    <article class="info-card">
      <div class="info-header">
        <div class="info-pill">
          {% if pageLabel %}{{ pageLabel }}{% else %}Rofo{% endif %}
        </div>

        <h1>{{ title }}</h1>

        {% if description %}
          <p class="info-dek">{{ description }}</p>
        {% endif %}
      </div>

      <div class="info-body">
        {{ content | safe }}
      </div>
    </article>
  </div>
</section>