<section class="section" id="contact">
  <div class="container split-band">

    <!-- ✅ UPDATED LEFT PANEL -->
    <div class="cta-band">
      <div class="kicker" style="color:#d9e6ff;">Get Help</div>
      <h2 style="margin:10px 0 12px;">Tell us what you need</h2>

      <p class="cta-band__lead">
        Help us understand your space, timing, and priorities—we’ll point you in the right direction.
      </p>

      <div class="cta-band__prompts">
        <div class="cta-band__prompt">
          <strong>Type of space</strong>
