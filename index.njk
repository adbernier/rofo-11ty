        <div class="cta-band__prompt">
          <strong>Size or team</strong>
          <span>A rough range or headcount is enough</span>
        </div>

        <div class="cta-band__prompt">
          <strong>Location</strong>
          <span>Your target area or nearby options</span>
        </div>

        <div class="cta-band__prompt">
          <strong>Timeline</strong>
          <span>Now, soon, or just exploring</span>
        </div>
      </div>

      <div class="cta-band__footer">
        You don’t need all the answers—we’ll help you figure it out.
      </div>
    </div>

    <!-- FORM (unchanged) -->
    <div class="form-card">
      <div class="eyebrow">Get Help</div>
      <h2>Find space that fits your business</h2>
      <p>Tell us what you need—we’ll follow up with a few options.</p>

      <form action="https://formspree.io/f/xreoadbr" method="POST">
        <input type="hidden" name="source" value="rofo-homepage">
        <input type="hidden" name="page_type" value="homepage">
        <input type="hidden" name="page_url" value="{{ page.url }}">

        <div class="form-stack">
          <div class="field">
            <label>Name</label>
            <input name="name" type="text" placeholder="Your name" required>
          </div>
        </div>

        <div class="form-stack">
          <div class="field">
            <label>Email</label>
            <input name="email" type="email" placeholder="you@example.com" required>
          </div>
        </div>

        <div class="form-stack">
          <div class="field">
            <label>Space needed <span class="optional">(optional)</span></label>
            <select name="space_needed">
              <option value="">Select one</option>
              <option>Under 1,000 sqft</option>
              <option>1,000–2,500 sqft</option>
              <option>2,500–5,000 sqft</option>
              <option>5,000–10,000 sqft</option>
              <option>10,000+ sqft</option>
            </select>
          </div>
        </div>

        <div class="form-stack">
          <div class="field">
            <label>Timeline <span class="optional">(optional)</span></label>
            <select name="timeline">
              <option value="">Select one</option>
              <option>ASAP</option>
              <option>Within 3 months</option>
              <option>Within 6 months</option>
              <option>6+ months</option>
              <option>Just exploring</option>
            </select>
          </div>
        </div>

        <div class="form-stack">
          <div class="field">
            <label>Anything else? <span class="optional">(optional)</span></label>
            <textarea name="notes"></textarea>
          </div>
        </div>

        <div class="btn-row">
          <button class="btn btn-primary" type="submit">Show Me Options</button>
        </div>

        <p class="form-note">
          No spam. Just helpful options to get you started.
        </p>
      </form>
    </div>

  </div>
</section>