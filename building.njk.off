---
layout: base.njk
pagination:
  data: buildings
  size: 1
  alias: building
permalink: "/commercial-real-estate/building/{{ building.state_abbr }}/{{ building.city_slug }}/{{ building.slug }}-{{ building.id }}.html"
title: "{{ building.address }} in {{ building.city }}, {{ building.state_abbr }}"
description: "Explore {{ building.address }} and nearby commercial real estate options in {{ building.city }}, {{ building.state_abbr }}."
---

<section class="section">
  <div class="container">
    <div class="eyebrow">Building</div>
    <h1>{{ building.address }}</h1>
    <p class="lead">{{ building.city }}, {{ building.state_abbr }}</p>
  </div>
</section>
