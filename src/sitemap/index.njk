---
layout: base.njk
title: Sitemap
---

<section class="section">
  <div class="container">
    <div class="eyebrow">Sitemap</div>
    <h1>Browse Rofo Pages</h1>
    <p class="lead">
      Explore markets, cities, and key pages across Rofo.
    </p>
  </div>
</section>

<section class="section" style="padding-top:0;">
  <div class="container">
    <div class="panel" style="margin-bottom:24px;">
      <div class="kicker">Core Pages</div>
      <div class="hero-search-links" style="margin-top:16px;">
        <a href="/">Home</a>
        <a href="/markets/">Markets</a>
        <a href="/privacy/">Privacy Policy</a>
        <a href="/terms/">Terms of Use</a>
        <a href="/sitemap.xml">XML Sitemap</a>
      </div>
    </div>

    <div class="panel" style="margin-bottom:24px;">
      <div class="kicker">Featured Markets</div>
      <div class="hero-search-links" style="margin-top:16px;">
        {% for city in cities %}
          {% if city.is_featured %}
            <a href="{{ city.path }}">{{ city.label }}</a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% set stateList = [] %}
    {% for city in cities %}
      {% if stateList.indexOf(city.state_abbr) == -1 %}
        {% set stateList = stateList.concat([city.state_abbr]) %}
      {% endif %}
    {% endfor %}

    {% for state in stateList | sort %}
      <div class="panel" style="margin-bottom:24px;">
        <div class="kicker">{{ stateNames[state] or state }}</div>
        <div class="hero-search-links" style="margin-top:16px;">
          {% for city in cities %}
            {% if city.state_abbr == state %}
              <a href="{{ city.path }}">{{ city.label }}</a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>