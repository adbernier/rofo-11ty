---
layout: base.njk
pagination:
  data: sampleBuildings
  size: 1
  alias: building
permalink: "/commercial-real-estate/{{ building.state_abbr }}/{{ building.city_slug }}/buildings/{{ building.building_slug }}/index.html"
title: "{{ building.name }} | {{ building.city }}, {{ building.state_abbr }}"
description: "Explore {{ building.name }}, a representative {{ building.type | lower }} property in {{ building.city }}, {{ building.state_abbr }}."
---

<style>
  .building-page {
    padding: 32px 0 56px;
  }

  .building-page .building-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .building-page .building-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.95fr);
    gap: 24px;
    align-items: stretch;
    margin-bottom: 24px;
  }

  .building-page .building-card,
  .building-page .building-sidecard,
  .building-page .building-stat,
  .building-page .building-form {
    background: #fff;
    border: 1px solid #d8e0ea;
    border-radius: 18px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
  }

  .building-page .building-card,
  .building-page .building-sidecard,
  .building-page .building-form {
    padding: 24px;
  }

  .building-page .eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #556274;
    margin-bottom: 10px;
  }

  .building-page h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.08;
    margin: 0 0 14px;
    color: #0f172a;
  }

  .building-page h2 {
    font-size: 1.55rem;
    line-height: 1.2;
    margin: 0 0 14px;
    color: #0f172a;
  }

  .building-page h3 {
    font-size: 1.08rem;
    line-height: 1.25;
    margin: 0 0 10px;
    color: #0f172a;
  }

  .building-page p {
    color: #334155;
    line-height: 1.65;
    margin: 0 0 14px;
  }

  .building-page .lead {
    font-size: 1.05rem;
    color: #475569;
    max-width: 62ch;
  }

  .building-page .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
  }

  .building-page .pill {
    display: inline-flex;
    align-items: center;
    padding: 8px 12px;
    border-radius: 999px;
    background: #f1f5f9;
    color: #0f172a;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .building-page .hero-image {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    display: block;
    border-radius: 14px;
  }

  .building-page .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .building-page .building-stat {
    padding: 18px;
  }

  .building-page .stat-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 8px;
  }

  .building-page .stat-value {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .building-page .stat-note {
    color: #64748b;
    font-size: 0.92rem;
    margin: 0;
  }

  .building-page .building-main {
    display: grid;
    grid-template-columns: minmax(0, 1.9fr) minmax(280px, 0.95fr);
    gap: 24px;
    align-items: start;
  }

  .building-page .stack {
    display: grid;
    gap: 24px;
  }

  .building-page .detail-list {
    display: grid;
    gap: 14px;
  }

  .building-page .detail-row {
    border-top: 1px solid #e2e8f0;
    padding-top: 14px;
  }

  .building-page .detail-row:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .building-page .detail-label {
    font-size: 0.9rem;
    font-weight: 700;
    color: #64748b;
    margin-bottom: 4px;
  }

  .building-page .detail-value {
    color: #0f172a;
    font-weight: 600;
  }

  .building-page .building-link,
  .building-page .back-link {
    color: #1346d8;
    text-decoration: none;
    font-weight: 600;
  }

  .building-page .building-link:hover,
  .building-page .back-link:hover {
    text-decoration: underline;
  }

  .building-page .building-form label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: #334155;
    margin-bottom: 6px;
  }

  .building-page .building-form input,
  .building-page .building-form textarea {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    padding: 12px 13px;
    font: inherit;
    color: #0f172a;
    background: #fff;
  }

  .building-page .building-form textarea {
    min-height: 120px;
    resize: vertical;
  }

  .building-page .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .building-page .field + .field {
    margin-top: 12px;
  }

  .building-page .form-grid .field + .field {
    margin-top: 0;
  }

  .building-page .btn-primary,
  .building-page .btn-secondary {
    display: inline-block;
    border-radius: 12px;
    padding: 12px 18px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
  }

  .building-page .btn-primary {
    border: 0;
    background: #1346d8;
    color: #fff;
  }

  .building-page .btn-secondary {
    background: #f8fafc;
    border: 1px solid #cbd5e1;
    color: #0f172a;
  }

  .building-page .mini-list {
    margin: 0;
    padding-left: 18px;
    color: #475569;
    line-height: 1.7;
  }

  @media (max-width: 980px) {
    .building-page .building-hero,
    .building-page .building-main {
      grid-template-columns: 1fr;
    }

    .building-page .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .building-page .stats-grid,
    .building-page .form-grid {
      grid-template-columns: 1fr;
    }

    .building-page .building-shell {
      padding: 0 16px;
    }

    .building-page .building-card,
    .building-page .building-sidecard,
    .building-page .building-stat,
    .building-page .building-form {
      padding: 18px;
    }
  }
</style>

<section class="building-page">
  <div class="building-shell">

    <div class="building-hero">
      <div class="building-card">
        <div class="eyebrow">Building</div>
        <h1>{{ building.name }}</h1>
        <p class="lead">
          Explore this representative {{ building.type | lower }} property in {{ building.city }}, {{ building.state_abbr }}.
        </p>

        <div class="pill-row">
          <span class="pill">{{ building.type }}</span>
          <span class="pill">{{ building.size }}</span>
          <span class="pill">{{ building.city }}, {{ building.state_abbr }}</span>
        </div>
      </div>

      <div class="building-sidecard">
        <img
          class="hero-image"
          src="{{ building.hero_image or '/images/cities/city.jpg' }}"
          alt="{{ building.name }}"
        />
      </div>
    </div>

    <div class="stats-grid">
      <div class="building-stat">
        <div class="stat-label">Address</div>
        <div class="stat-value">{{ building.address }}</div>
        <p class="stat-note">Representative property location</p>
      </div>

      <div class="building-stat">
        <div class="stat-label">Type</div>
        <div class="stat-value">{{ building.type }}</div>
        <p class="stat-note">Property category</p>
      </div>

      <div class="building-stat">
        <div class="stat-label">Size</div>
        <div class="stat-value">{{ building.size }}</div>
        <p class="stat-note">Approximate building size</p>
      </div>

      <div class="building-stat">
        <div class="stat-label">Market</div>
        <div class="stat-value">{{ building.city }}</div>
        <p class="stat-note">{{ building.state_abbr }}</p>
      </div>
    </div>

    <div class="building-main">
      <div class="stack">
        <div class="building-card">
          <div class="eyebrow">Overview</div>
          <h2>About {{ building.name }}</h2>
          <p>
            {{ building.name }} is a sample {{ building.type | lower }} property page for {{ building.city }}, {{ building.state_abbr }}.
            This content stands in for the fuller property data you can later pull from the Rofo database.
          </p>
          <p>
            Use this template as the foundation for future building pages, including real photos, descriptions,
            availability details, amenities, and inquiry flows.
          </p>
        </div>

        <div class="building-card">
          <div class="eyebrow">Property Details</div>
          <h2>Representative building information</h2>

          <div class="detail-list">
            <div class="detail-row">
              <div class="detail-label">Building Name</div>
              <div class="detail-value">{{ building.name }}</div>
            </div>

            <div class="detail-row">
              <div class="detail-label">Address</div>
              <div class="detail-value">{{ building.address }}</div>
            </div>

            <div class="detail-row">
              <div class="detail-label">Property Type</div>
              <div class="detail-value">{{ building.type }}</div>
            </div>

            <div class="detail-row">
              <div class="detail-label">Approximate Size</div>
              <div class="detail-value">{{ building.size }}</div>
            </div>

            <div class="detail-row">
              <div class="detail-label">Market</div>
              <div class="detail-value">{{ building.city }}, {{ building.state_abbr }}</div>
            </div>
          </div>
        </div>

        <div class="building-card">
          <div class="eyebrow">Next Step</div>
          <h2>Explore more in {{ building.city }}</h2>
          <p>
            Continue browsing the broader {{ building.city }} market to compare representative buildings
            and nearby opportunities.
          </p>

          <a class="btn-secondary" href="/commercial-real-estate/{{ building.state_abbr }}/{{ building.city_slug }}/">
            Back to {{ building.city }} Market
          </a>
        </div>
      </div>

      <div class="stack">
        <div class="building-form">
          <div class="eyebrow">Get Help</div>
          <h2>Interested in {{ building.city }}?</h2>
          <p>
            Tell us what kind of space you need and we can help point you in the right direction.
          </p>

          <div class="form-grid">
            <div class="field">
              <label>Email</label>
              <input type="email" placeholder="Your email">
            </div>
            <div class="field">
              <label>Market</label>
              <input type="text" value="{{ building.city }}, {{ building.state_abbr }}">
            </div>
          </div>

          <div class="field">
            <label>Property type</label>
            <input type="text" value="{{ building.type }}">
          </div>

          <div class="field">
            <label>What are you looking for?</label>
            <textarea placeholder="Size, neighborhood, timing, budget, use case, etc."></textarea>
          </div>

          <div style="margin-top: 14px;">
            <button class="btn-primary">Submit</button>
          </div>
        </div>

        <div class="building-card">
          <div class="eyebrow">Why Rofo</div>
          <h2>Commercial real estate discovery</h2>
          <p>
            Rofo helps businesses explore markets, compare representative properties,
            and narrow their search more efficiently.
          </p>

          <ul class="mini-list">
            <li>Start with market-level context</li>
            <li>Review representative buildings</li>
            <li>Compare cities and nearby options</li>
            <li>Get help narrowing your search</li>
          </ul>
        </div>
      </div>
    </div>

  </div>
</section>