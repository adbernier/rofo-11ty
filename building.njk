---
layout: base.njk
pagination:
  data: buildingPages
  size: 1
  alias: building
permalink: "/commercial-real-estate/building/{{ building.state_abbr }}/{{ building.city_slug }}/{{ building.building_slug }}/index.html"
eleventyComputed:
  title: >
    {{ building.address }} in {{ building.city }}, {{ building.state_abbr }} | Commercial Real Estate | Rofo
  description: >
    {{ building.address }} is a flexible {{ building.type | lower }} location in {{ building.city }}, {{ building.state_abbr }}.
---

{% set placeholderSrc = building | buildingPlaceholder %}
{% set stateName = stateNames[building.state_abbr] or building.state_abbr %}
{% set crumbs = [
  { "label": "Markets", "url": "/markets/" },
  { "label": stateName, "url": "/commercial-real-estate/" + building.state_abbr + "/" },
  { "label": building.city + ", " + building.state_abbr, "url": "/commercial-real-estate/" + building.state_abbr + "/" + building.city_slug + "/" },
  { "label": building.address, "url": page.url }
] %}

<section class="building-page">
  <div class="building-shell">
    {% include "partials/breadcrumbs.njk" %}

    <div class="building-hero">
      <div class="building-card">
        <div class="eyebrow">Building</div>
        <h1>{{ building.address }}</h1>
        <p class="lead">
          {{ building.address }} is a flexible {{ building.type | lower }} location in {{ building.city }}, {{ building.state_abbr }}, offering {{ building.size_label | lower }} for businesses of all sizes.
        </p>

        <div class="pill-row">
          <span class="pill">{{ building.type }}</span>
          {% if building.size_label %}
            <span class="pill">{{ building.size_label }}</span>
          {% endif %}
          <span class="pill">{{ building.city }}, {{ building.state_abbr }}</span>
        </div>
      </div>

      <div class="building-sidecard">
        <div class="hero-media">
          <img
            class="hero-image"
            src="{{ building.hero_image or placeholderSrc }}"
            alt="{{ building.name or building.address }} in {{ building.city }}, {{ building.state_abbr }}"
            width="1600"
            height="900"
            decoding="async"
            fetchpriority="high"
            loading="eager"
          />
          <div class="hero-overlay">
            <p class="hero-overlay-title">{{ building.address }}</p>
            <p class="hero-overlay-meta">{{ building.type }} · {{ building.city }}, {{ building.state_abbr }}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="building-stat">
        <div class="stat-label">Address</div>
        <div class="stat-value">{{ building.address }}</div>
        <p class="stat-note">Representative property location</p>
      </div>

      <div class="building-stat">
        <div class="stat-label">Type</div>
        <div class="stat-value">{{ building.type }}</div>
        <p class="stat-note">Property category</p>
      </div>

      <div class="building-stat">
        <div class="stat-label">Typical Space</div>
        <div class="stat-value">{{ building.size_label }}</div>
        <p class="stat-note">Common suite configuration</p>
      </div>

      <div class="building-stat">
        <div class="stat-label">Market</div>
        <div class="stat-value">{{ building.city }}</div>
        <p class="stat-note">{{ building.state_abbr }}</p>
      </div>
    </div>

    <div class="building-main">
      <div class="stack">
        <div class="building-card">
          <div class="eyebrow">Overview</div>
          <h2>About {{ building.address }}</h2>
          <p>
            {{ building.address }} is a flexible workspace location in {{ building.city }}, {{ building.state_abbr }}, offering options suited for small teams, growing companies, and established businesses.
          </p>
          <p>
            This representative building reflects the types of office and workspace environments commonly found throughout the {{ building.city }} market.
          </p>
        </div>

        <div class="building-card">
          <div class="eyebrow">Property Details</div>
          <h2>Representative building information</h2>

          <div class="detail-list">
            <div class="detail-row">
              <div class="detail-label">Address</div>
              <div class="detail-value">{{ building.address }}</div>
            </div>

            <div class="detail-row">
              <div class="detail-label">Property Type</div>
              <div class="detail-value">{{ building.type }}</div>
            </div>

            <div class="detail-row">
              <div class="detail-label">Typical Space</div>
              <div class="detail-value">{{ building.size_label }}</div>
            </div>

            <div class="detail-row">
              <div class="detail-label">Market</div>
              <div class="detail-value">{{ building.city }}, {{ building.state_abbr }}</div>
            </div>

            <div class="detail-row">
              <div class="detail-label">Summary</div>
              <div class="detail-value">Flexible workspace and office configurations typical for this market.</div>
            </div>
          </div>
        </div>

{% include "partials/building/building-guidance-card.njk" %}

        <div class="building-card">
          <div class="eyebrow">Next Step</div>
          <h2>Explore more in {{ building.city }}</h2>
          <p>
            Continue browsing the broader {{ building.city }} market to compare buildings and nearby opportunities.
          </p>

          <a class="btn-secondary" href="/commercial-real-estate/{{ building.state_abbr }}/{{ building.city_slug }}/">
            Back to {{ building.city }} Market
          </a>
        </div>
      </div>

      <div class="stack">
        <div class="building-form">
  <form
    action="https://formspree.io/f/xreoadbr"
    method="POST"
  >
    <div class="eyebrow">Get Help</div>
    <h2>Want options like this?</h2>
    <p>
      We’ll help you find similar spaces or better options nearby.
    </p>

    <input type="text" name="_gotcha" style="display:none">
    <input type="hidden" name="source" value="rofo-building-page" />
    <input type="hidden" name="lead_type" value="building" />
    <input type="hidden" name="page_type" value="building" />
    <input type="hidden" name="page_url" value="{{ metadata.siteUrl }}{{ page.url }}" />

    <input type="hidden" name="building_name" value="{{ building.name or '' }}" />
    <input type="hidden" name="building_address" value="{{ building.address or '' }}" />
    <input type="hidden" name="building_slug" value="{{ building.building_slug or '' }}" />

    <input type="hidden" name="city" value="{{ building.city or '' }}" />
    <input type="hidden" name="state" value="{{ building.state_abbr or '' }}" />
    <input type="hidden" name="market" value="{{ building.city or '' }}, {{ building.state_abbr or '' }}" />
    <input type="hidden" name="space_type" value="{{ building.type or '' }}" />

    <input type="hidden" name="primary_source" value="{{ building.primary_source or '' }}" />
    <input type="hidden" name="building_company" value="{{ building.company or building.primary_source or '' }}" />
    <input type="hidden" name="building_source_companies" value="{{ (building.source_companies or []) | join(', ') }}" />
    <input type="hidden" name="building_space_types" value="{{ (building.space_types or []) | join(', ') }}" />
    <input type="hidden" name="is_exec_suite_present" value="{{ building.is_exec_suite_present or false }}" />

    <input type="hidden" name="routing_key" value="{{ (building.primary_source or 'unknown') | lower }}__{{ building.city_slug or '' }}__{{ (building.type or 'unknown') | lower }}" />

      <div class="field">
        <label for="building-lead-email">Email</label>
        <input
          id="building-lead-email"
          name="email"
          type="email"
          placeholder="Your email"
          required
        >
      </div>

      <div class="field">
        <label for="building-lead-type">Type of Space</label>
        <input
          id="building-lead-type"
          type="text"
          value="{{ building.type }}"
          disabled
        >
      </div>

      <div class="field">
        <label for="building-lead-notes">What are you looking for?</label>
        <textarea
          id="building-lead-notes"
          name="notes"
          placeholder="Example: 2–4 person office, move in May, flexible budget"
        ></textarea>
      </div>

      <div class="btn-row">
        <button class="btn-primary" type="submit">Get Options Like This</button>
      </div>

    <p class="form-note">✓ No cost • ✓ No obligation • ✓ Local Expertise</p>
  </form>
</div>

        <div class="building-card">
          <div class="eyebrow">Why Rofo</div>
          <h2>Commercial real estate discovery</h2>
          <p>
            Rofo helps businesses explore markets, compare buildings, and narrow their search more efficiently.
          </p>

          <ul class="mini-list">
            <li>Explore markets quickly</li>
            <li>Compare representative buildings</li>
            <li>Evaluate nearby options</li>
            <li>Get help finding the right space</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
