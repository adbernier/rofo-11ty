---
layout: base.njk
pagination:
  data: cities
  size: 1
  alias: city
permalink: "/commercial-real-estate/{{ city.state_abbr }}/{{ city.slug }}/buildings/index.html"
eleventyComputed:
  title: "Buildings in {{ city.city }}, {{ city.state_abbr }} | Rofo"
  description: "Browse representative office, retail, and flexible workspace buildings in {{ city.city }}, {{ city.state_abbr }}."
---
{% set stateName = stateNames[city.state_abbr] or city.state_abbr %}
{% set crumbs = [
  { "label": "Markets", "url": "/markets/" },
  { "label": stateName, "url": "/commercial-real-estate/" + city.state_abbr + "/" },
  { "label": city.city + ", " + city.state_abbr, "url": "/commercial-real-estate/" + city.state_abbr + "/" + city.slug + "/" },
  { "label": "Buildings", "url": page.url }
] %}

{% set cityBuildings = [] %}
{% for b in sampleBuildings %}
  {% if b.city == city.city and b.state_abbr == city.state_abbr %}
    {% set cityBuildings = (cityBuildings.push(b), cityBuildings) %}
  {% endif %}
{% endfor %}

<style>
  .city-buildings-page {
    padding: 8px 0 56px;
  }

  .city-buildings-page .city-buildings-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .city-buildings-page .city-buildings-hero {
    margin-bottom: 24px;
  }

  .city-buildings-page h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.08;
    margin: 0 0 14px;
    color: #0f172a;
  }

  .city-buildings-page h2 {
    font-size: 1.45rem;
    line-height: 1.2;
    margin: 0 0 12px;
    color: #0f172a;
  }

  .city-buildings-page p {
    color: #334155;
    line-height: 1.65;
    margin: 0 0 14px;
  }

  .city-buildings-page .lead {
    font-size: 1.05rem;
    color: #475569;
    max-width: 68ch;
  }

  .city-buildings-page .top-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-top: 16px;
  }

  .city-buildings-page .summary-card {
    margin-bottom: 24px;
  }

  .city-buildings-page .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .city-buildings-page .summary-stat {
    padding: 18px;
  }

  .city-buildings-page .stat-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 8px;
  }

  .city-buildings-page .stat-value {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .city-buildings-page .stat-note {
    color: #64748b;
    font-size: 0.92rem;
    margin: 0;
  }

  .city-buildings-page .buildings-card {
    padding: 20px;
  }

  .city-buildings-page .buildings-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 14px;
  }

  .city-buildings-page .buildings-header__meta {
    font-size: 0.95rem;
    color: #64748b;
    margin: 0;
  }

  .city-buildings-page .buildings-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .city-buildings-page .empty-state {
    padding: 24px;
  }

  @media (max-width: 980px) {
    .city-buildings-page .summary-grid,
    .city-buildings-page .buildings-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .city-buildings-page .summary-grid,
    .city-buildings-page .buildings-grid {
      grid-template-columns: 1fr;
    }

    .city-buildings-page .city-buildings-shell {
      padding: 0 16px;
    }

    .city-buildings-page .buildings-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<section class="city-buildings-page">
  <div class="city-buildings-shell">
    {% include "partials/breadcrumbs.njk" %}

    <div class="city-buildings-hero city-card">
      <div class="eyebrow">Buildings</div>
      <h1>Buildings in {{ city.city }}, {{ city.state_abbr }}</h1>
      <p class="lead">
        Browse representative office, retail, and flexible workspace buildings in {{ city.city }}. Use this page to explore locations, compare options, and click through to individual building pages.
      </p>

      <div class="top-actions">
        <a class="btn-secondary" href="/commercial-real-estate/{{ city.state_abbr }}/{{ city.slug }}/">
          Back to {{ city.city }} Market
        </a>
        <a class="btn-primary" href="#city-buildings-list">
          Browse Buildings
        </a>
      </div>
    </div>

    <div class="summary-card city-card">
      <div class="summary-grid">
        <div class="summary-stat">
          <div class="stat-label">Market</div>
          <div class="stat-value">{{ city.city }}</div>
          <p class="stat-note">{{ city.state_abbr }}</p>
        </div>

        <div class="summary-stat">
          <div class="stat-label">Buildings Listed</div>
          <div class="stat-value">{{ cityBuildings.length }}</div>
          <p class="stat-note">Representative buildings on this page</p>
        </div>

        <div class="summary-stat">
          <div class="stat-label">Browse</div>
          <div class="stat-value">All Buildings</div>
          <p class="stat-note">Explore the full city building list</p>
        </div>
      </div>
    </div>

    <div id="city-buildings-list" class="buildings-card city-card">
      <div class="buildings-header">
        <div>
          <div class="eyebrow">Inventory</div>
          <h2>All Buildings in {{ city.city }}</h2>
        </div>
        <p class="buildings-header__meta">
          {{ cityBuildings.length }} buildings
        </p>
      </div>

      {% if cityBuildings.length %}
        <div class="buildings-grid">
          {% for b in cityBuildings %}
            {% set building = b %}
            {% include "partials/shared/building-card-compact.njk" %}
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <p>No buildings are available for this market yet.</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>