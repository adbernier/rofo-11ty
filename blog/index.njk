---
layout: base.njk
permalink: "/blog/index.html"
title: "Rofo Blog | Commercial Real Estate Insights"
description: "Commercial real estate insights, leasing guides, and market resources for businesses searching for office, retail, and industrial space."
---

{% set blogPosts = collections.blog or [] %}
{% set featuredPosts = blogPosts | reverse | slice(0, 3) %}
{% set latestPosts = blogPosts | reverse %}

<style>
  .blog-page {
    padding: 8px 0 56px;
  }

  .blog-page .blog-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .blog-page .blog-hero,
  .blog-page .blog-card,
  .blog-page .topic-card,
  .blog-page .post-card,
  .blog-page .cta-card {
    background: #fff;
    border: 1px solid #d8e0ea;
    border-radius: 18px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
  }

  .blog-page .blog-hero,
  .blog-page .blog-card,
  .blog-page .cta-card {
    padding: 24px;
  }

  .blog-page .blog-hero {
    max-width: 100%;
  }

  .blog-page .eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #556274;
    margin: 0 0 6px;
  }

  .blog-page h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.08;
    margin: 0 0 14px;
    color: #0f172a;
    max-width: 25ch;
  }

  .blog-page h2 {
    font-size: 1.55rem;
    line-height: 1.2;
    margin: 0 0 14px;
    color: #0f172a;
  }

  .blog-page h3 {
    font-size: 1.08rem;
    line-height: 1.25;
    margin: 0 0 10px;
    color: #0f172a;
  }

  .blog-page p {
    color: #334155;
    line-height: 1.65;
    margin: 0 0 14px;
  }

  .blog-page .lead {
    font-size: 1.05rem;
    color: #475569;
    max-width: 62ch;
  }

  .blog-page .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 18px;
  }

  .blog-page .btn-primary,
  .blog-page .btn-secondary {
    display: inline-block;
    border-radius: 12px;
    padding: 12px 18px;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
  }

  .blog-page .btn-primary {
    background: #1346d8;
    color: #fff;
    border: 0;
  }

  .blog-page .btn-secondary {
    background: #f1f5f9;
    color: #0f172a;
    border: 1px solid #d8e0ea;
  }

  .blog-page .section-stack {
    display: grid;
    gap: 24px;
    margin-top: 24px;
  }

  .blog-page .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .blog-page .topics-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .blog-page .latest-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .blog-page .topic-card,
  .blog-page .post-card {
    padding: 20px;
  }

  .blog-page .post-meta {
    color: #64748b;
    font-size: 0.92rem;
    margin-bottom: 10px;
  }

  .blog-page .post-card a,
  .blog-page .topic-card a {
    color: #1346d8;
    text-decoration: none;
    font-weight: 600;
  }

  .blog-page .post-card a:hover,
  .blog-page .topic-card a:hover {
    text-decoration: underline;
  }

  .blog-page .topic-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 12px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .blog-page .topic-pill {
    display: inline-flex;
    align-items: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: #f8fafc;
    border: 1px solid #d8e0ea;
    color: #0f172a;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
  }

  .blog-page .topic-pill:hover {
    background: #eff6ff;
    text-decoration: none;
  }

  .blog-page .cta-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 20px;
  }

  .blog-page .empty-state {
    color: #64748b;
    margin: 0;
  }

  @media (max-width: 980px) {
    .blog-page .featured-grid,
    .blog-page .topics-grid,
    .blog-page .latest-grid {
      grid-template-columns: 1fr;
    }

    .blog-page .cta-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .blog-page .blog-shell {
      padding: 0 16px;
    }

    .blog-page .blog-hero,
    .blog-page .blog-card,
    .blog-page .topic-card,
    .blog-page .post-card,
    .blog-page .cta-card {
      padding: 20px;
    }

    .blog-page h1 {
      max-width: none;
    }
  }
</style>

<section class="blog-page">
  <div class="blog-shell">

    <div class="blog-hero">
      <div class="eyebrow">Rofo Blog</div>
      <h1>Commercial Real Estate Insights for Growing Businesses</h1>
      <p class="lead">
        Explore market guides, lease-rate articles, and practical advice to help you evaluate office, retail, and industrial space with more confidence.
      </p>

      <div class="hero-actions">
        <a class="btn-primary" href="/markets/">Explore Markets</a>
        <a class="btn-secondary" href="/for-brokers-landlords/">For Brokers &amp; Landlords</a>
      </div>
    </div>

    <div class="section-stack">
      <div class="blog-card">
        <div class="eyebrow">Featured Articles</div>
        <h2>Start here</h2>

        {% if featuredPosts and featuredPosts.length %}
          <div class="featured-grid">
            {% for post in featuredPosts %}
              <article class="post-card">
                <div class="post-meta">
                  {% if post.data.category %}{{ post.data.category }}{% else %}Article{% endif %}
                </div>
                <h3>
                  <a href="{{ post.url }}">{{ post.data.title }}</a>
                </h3>
                {% if post.data.description %}
                  <p>{{ post.data.description }}</p>
                {% elseif post.data.excerpt %}
                  <p>{{ post.data.excerpt }}</p>
                {% else %}
                  <p>Read this article on commercial real estate strategy, markets, and leasing decisions.</p>
                {% endif %}
                <a href="{{ post.url }}">Read article</a>
              </article>
            {% endfor %}
          </div>
        {% else %}
          <p class="empty-state">No blog posts yet. Add your first posts and they’ll appear here automatically.</p>
        {% endif %}
      </div>

      <div class="blog-card">
        <div class="eyebrow">Browse by Topic</div>
        <h2>Popular topics</h2>
        <ul class="topic-list">
          <li><a class="topic-pill" href="/blog/tag/lease-rates/">Lease Rates</a></li>
          <li><a class="topic-pill" href="/blog/tag/office-space/">Office Space</a></li>
          <li><a class="topic-pill" href="/blog/tag/retail-space/">Retail Space</a></li>
          <li><a class="topic-pill" href="/blog/tag/industrial-space/">Industrial Space</a></li>
          <li><a class="topic-pill" href="/blog/tag/leasing-guides/">Leasing Guides</a></li>
          <li><a class="topic-pill" href="/blog/tag/city-guides/">City Guides</a></li>
        </ul>
      </div>

      <div class="blog-card">
        <div class="eyebrow">Latest</div>
        <h2>Recent articles</h2>

        {% if latestPosts and latestPosts.length %}
          <div class="latest-grid">
            {% for post in latestPosts %}
              <article class="post-card">
                <div class="post-meta">
                  {% if post.data.category %}{{ post.data.category }}{% else %}Article{% endif %}
                </div>
                <h3>
                  <a href="{{ post.url }}">{{ post.data.title }}</a>
                </h3>
                {% if post.data.description %}
                  <p>{{ post.data.description }}</p>
                {% elseif post.data.excerpt %}
                  <p>{{ post.data.excerpt }}</p>
                {% else %}
                  <p>Read this article on commercial real estate strategy, markets, and leasing decisions.</p>
                {% endif %}
                <a href="{{ post.url }}">Read article</a>
              </article>
            {% endfor %}
          </div>
        {% else %}
          <p class="empty-state">No posts yet.</p>
        {% endif %}
      </div>

      <div class="cta-card">
        <div>
          <div class="eyebrow">Need help?</div>
          <h2>Looking for space in a specific market?</h2>
          <p>Explore available buildings, compare neighborhoods, and connect with local experts.</p>
        </div>
        <div>
          <a class="btn-primary" href="/markets/">Explore Markets</a>
        </div>
      </div>
    </div>

  </div>
</section>