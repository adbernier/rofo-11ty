---
layout: base.njk
pagination:
  data: cities
  size: 1
  alias: city
permalink: "/commercial-real-estate/{{ city.state_abbr }}/{{ city.slug }}/index.html"
eleventyComputed:
  title: >
    {% if city.seo_title %}
      {{ city.seo_title }}
    {% else %}
      Commercial Real Estate in {{ city.city }}, {{ city.state_abbr }} | Office, Retail, Industrial | Rofo
    {% endif %}
  description: >
    {% if city.seo_description %}
      {{ city.seo_description }}
    {% else %}
      Explore office, retail, and industrial space in {{ city.city }}, {{ city.state_abbr }}. Browse representative buildings, compare nearby markets, and get help finding the right space.
    {% endif %}
---
{% set stateName = stateNames[city.state_abbr] or city.state_abbr %}
{% set crumbs = [
  { "label": "Markets", "url": "/markets/" },
  { "label": stateName, "url": "/commercial-real-estate/" + city.state_abbr + "/" },
  { "label": city.city + ", " + city.state_abbr, "url": page.url }
] %}

{% set marketHeading = city.market_context_heading or "" %}
{% set marketParagraph1 = city.market_context_paragraph1 or "" %}
{% set marketParagraph2 = city.market_context_paragraph2 or "" %}
{% set hasMarketContext = (marketHeading | trim) or (marketParagraph1 | trim) or (marketParagraph2 | trim) %}

<style>
  .city-page {
    padding: 8px 0 56px;
  }

  .city-page .city-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .city-page .city-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(340px, 0.95fr);
    gap: 24px;
    align-items: stretch;
    margin-bottom: 24px;
  }

  .city-page .city-main {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(340px, 0.85fr);
    gap: 24px;
    align-items: start;
  }

  .city-page .city-main-left,
  .city-page .city-main-right {
    display: grid;
    gap: 24px;
    min-width: 0;
  }

  .city-page .city-hero-copy > * + * {
    margin-top: 14px;
  }

  .city-page h1 {
    font-size: clamp(1.85rem, 3.6vw, 2.7rem);
    line-height: 1.04;
    margin: 0;
    color: #0f172a;
    max-width: 16ch;
  }

  .city-page h2 {
    font-size: 1.55rem;
    line-height: 1.2;
    margin: 0 0 14px;
    color: #0f172a;
  }

  .city-page h3 {
    font-size: 1.08rem;
    margin: 0 0 10px;
    color: #0f172a;
  }

  .city-page p {
    color: #334155;
    line-height: 1.65;
    margin: 0 0 14px;
  }

  .city-page .lead {
    font-size: 1.05rem;
    color: #475569;
    max-width: 56ch;
    margin: 0;
  }

  .city-page .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 18px;
  }

  .city-page .hero-pill-wrap {
    margin-top: 18px;
  }

  .city-page .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
  }

  .city-page .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .city-page .city-stat {
    padding: 18px;
  }

  .city-page .stat-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 8px;
  }

  .city-page .stat-value {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 6px;
    line-height: 1.2;
  }

  .city-page .stat-note {
    color: #64748b;
    font-size: 0.92rem;
    margin: 0;
  }

  .city-page .building-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .city-page .market-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 12px;
  }

  .city-page .market-links a {
    display: inline-flex;
    align-items: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    font-size: 0.93rem;
    white-space: nowrap;
  }

  .city-page .hero-media {
    position: relative;
    height: 100%;
    min-height: 320px;
    border-radius: 14px;
    overflow: hidden;
  }

  .city-page .hero-image {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    display: block;
    border-radius: 14px;
  }

  .city-page .hero-overlay {
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 18px;
    padding: 16px 18px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(226, 232, 240, 0.95);
    backdrop-filter: blur(4px);
  }

  .city-page .hero-overlay-title {
    margin: 0 0 4px;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    color: #0f172a;
  }

  .city-page .hero-overlay-meta {
    margin: 0;
    font-size: 0.92rem;
    color: #64748b;
    line-height: 1.3;
  }

  .city-page .featured-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 12px;
  }

  .city-page .city-grid {
    display: grid;
    gap: 24px;
  }

  /* TABLET */
  @media (max-width: 980px) {
    .city-page .city-main,
    .city-page .city-hero {
      grid-template-columns: 1fr;
    }

    .city-page .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .city-page .building-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .city-page .city-shell {
      padding: 0 16px;
    }

    .city-page .featured-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .city-page h1 {
      max-width: 13ch;
    }
  }

  /* MOBILE */
  @media (max-width: 680px) {
    .city-page .stats-grid,
    .city-page .building-grid,
    .city-page .city-grid {
      grid-template-columns: 1fr;
    }

    .city-page .hero-actions {
      align-items: stretch;
    }

    .city-page h1 {
      max-width: none;
    }
  }

  /* =========================
   BUILDINGS TO EXPLORE CARD
   ========================= */

.city-page .buildings-explore-card {
  padding-bottom: 24px;
}

.city-page .buildings-explore-card > *:last-child {
  margin-bottom: 0;
}

.city-page .buildings-explore-card .featured-header,
.city-page .buildings-explore-card .featured-header--simple {
  display: block;
  margin-bottom: 0;
}

.city-page .buildings-explore-card h2 {
  margin: 0 0 10px;
}

.city-page .buildings-explore-card__intro {
  margin: 0;
  color: #475569;
  line-height: 1.5;
  max-width: 72ch;
}

.city-page .buildings-explore-card__grid {
  margin-top: 18px;
}

.city-page .buildings-explore-card__footer-link {
  margin-top: 18px;
}

.city-page .buildings-explore-card__footer-link a {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-weight: 700;
  text-decoration: none;
}

.city-page .buildings-explore-card__footer-link a:hover {
  text-decoration: underline;
}

</style>

<section class="city-page">
  <div class="city-shell">
    {% include "partials/breadcrumbs.njk" %}

    <div class="city-hero">
      <div class="city-card">
        <div class="city-hero-copy">
          <div class="eyebrow">Market</div>

          <h1>Commercial Real Estate in {{ city.city }}, {{ city.state_abbr }}</h1>

          <p class="lead">
            Explore office, retail, and industrial space for lease in {{ city.city }}, {{ city.state_abbr }}.
            Browse representative buildings, compare nearby markets, or get help finding available space.
          </p>

          <div class="hero-actions">
            <a class="btn-primary" href="#market-contact-form">Get Available Spaces in {{ city.city }}</a>
            <a class="btn-secondary" href="/commercial-real-estate/{{ city.state_abbr }}/{{ city.slug }}/buildings/">
              Browse Buildings
            </a>
          </div>

          <div class="hero-pill-wrap">
            {% include "partials/space-type/pill-nav.njk" %}
          </div>
        </div>
      </div>

      <div class="city-sidecard">
        <div class="hero-media">

          {% if city.hero_image %}
            <img
              class="hero-image"
              src="{{ city.hero_image }}"
              alt="{{ city.hero_image_alt or (city.city + ", " + city.state_abbr) }}"
              width="1200"
              height="400"
              fetchpriority="high"
              decoding="async"
            />
          {% else %}
            <div
              class="hero-image hero-image--placeholder hero-image--theme-{{ city.placeholder_theme }}"
              data-location="{{ city.city }}, {{ city.state_abbr }}"
              aria-label="{{ city.city }}, {{ city.state_abbr }}"
            ></div>
          {% endif %}

          <div class="hero-overlay">
            <p class="hero-overlay-title">{{ city.city }}, {{ city.state_abbr }}</p>
            <p class="hero-overlay-meta">Commercial Real Estate Market</p>
          </div>

        </div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="city-stat">
        <div class="stat-label">Market</div>
        <div class="stat-value">{{ city.city }}</div>
        <p class="stat-note">{{ city.state_abbr }}</p>
      </div>

      <div class="city-stat">
        <div class="stat-label">Market Type</div>
        <div class="stat-value">
          {% if city.tier == 1 %}Major Market
          {% elseif city.tier == 2 %}Established Market
          {% else %}Local Market{% endif %}
        </div>
        <p class="stat-note">General market classification</p>
      </div>

      <div class="city-stat">
        <div class="stat-label">County</div>
        <div class="stat-value">{{ city.county or "—" }}</div>
        <p class="stat-note">Local market context</p>
      </div>

      <div class="city-stat">
        <div class="stat-label">Coordinates</div>
        <div class="stat-value">{% if city.lat and city.lng %}{{ city.lat }}, {{ city.lng }}{% else %}—{% endif %}</div>
        <p class="stat-note">Reference location</p>
      </div>
    </div>

    {% include "partials/city/helpful-leasing-card.njk" %}

{# ===== FEATURED COMPANY CARD ===== #}
{% set company = companies[0] %}
{% include "partials/city/featured-company-card.njk" %}
{% include "partials/city/buildings-to-explore.njk" %}

<div class="city-main">
      <div class="city-main-left">
        <div class="city-card">
          <div class="eyebrow">Overview</div>
          <h2>Explore the {{ city.city }} market</h2>
          <p>
            {{ city.city }} is a
            {% if city.tier == 1 %}major{% elseif city.tier == 2 %}established{% else %}local{% endif %}
            commercial real estate market in {{ city.state_abbr }}.
          </p>
          <p>
            Businesses typically search here for office, retail, and industrial space for lease based on access, visibility, and proximity to customers or workforce.
            Many also compare {{ city.city }} with nearby markets to evaluate pricing, inventory, and location fit.
          </p>
        </div>

        <div class="city-grid">
          <div class="city-card seo-copy">
            <div class="eyebrow">About This Market</div>
            <h2>About commercial real estate in {{ city.city }}</h2>
            <p>
              {{ city.city }}, {{ city.state_abbr }} offers a mix of office, retail, and industrial real estate options for businesses at different stages of growth.
              Whether you are evaluating a first location, relocating, or expanding, this market can offer a range of property types and leasing options.
            </p>
            <p>
              Businesses often compare areas based on accessibility, surrounding amenities, workforce, and proximity to customers or logistics corridors.
              Rofo helps simplify that search by making it easier to explore buildings, compare nearby markets, and connect with help when you need it.
            </p>
            <p>
              Use this page to get a practical overview of the {{ city.city }} market, review featured properties, and expand your search into nearby cities if you want a wider set of options.
            </p>
          </div>

          {% if hasMarketContext %}
            <div class="city-card">
              <div class="eyebrow">Market Context</div>
              {% if marketHeading | trim %}
                <h2>{{ marketHeading }}</h2>
              {% endif %}
              {% if marketParagraph1 | trim %}
                <p>{{ marketParagraph1 }}</p>
              {% endif %}
              {% if marketParagraph2 | trim %}
                <p>{{ marketParagraph2 }}</p>
              {% endif %}
            </div>
          {% endif %}

                    <div class="city-card">
            <div class="eyebrow">Nearby Markets</div>
            <h2>Explore nearby markets</h2>
            <p>Businesses often consider these nearby markets when evaluating options in {{ city.city }}.</p>

            <div class="market-links">
              {% if city.nearby_cities and city.nearby_cities.length %}
                {% for nearby in city.nearby_cities %}
                  <a href="{{ nearby.path }}">
                    {{ nearby.city }}, {{ nearby.state_abbr }}
                  </a>
                {% endfor %}
              {% else %}
                <span class="subtle-note">Nearby markets will appear here as city coverage expands.</span>
              {% endif %}
            </div>
          </div>

          <div class="city-card">
            <div class="eyebrow">Popular Searches</div>
            <h2>Popular commercial real estate searches in {{ city.city }}</h2>
            <ul class="mini-list">
              <li>Office space for lease in {{ city.city }}</li>
              <li>Retail space for lease in {{ city.city }}</li>
              <li>Industrial space in {{ city.city }}</li>
              <li>Small office space in {{ city.city }}</li>
              <li>Coworking space in {{ city.city }}</li>
            </ul>
          </div>

          <div class="city-card">
            <div class="eyebrow">Resources</div>
            <h2>Helpful Resources for Businesses in {{ city.city }}</h2>
            <p>Learn more about leasing, pricing, and how to evaluate commercial space in {{ city.city }}.</p>
            <ul class="mini-list">
              <li>
                <a href="/blog/typical-lease-rates-in-{{ city.slug }}/">
                  Typical Lease Rates in {{ city.city }}
                </a>
              </li>
              <li>
                <a href="/blog/best-neighborhoods-for-office-space-in-{{ city.slug }}/">
                  Best Neighborhoods for Office Space in {{ city.city }}
                </a>
              </li>
              <li>
                <a href="/blog/how-to-evaluate-office-space-to-lease/">
                  How to Evaluate Office Space Before You Lease
                </a>
              </li>
            </ul>
          </div>

          <div class="city-card">
            <div class="eyebrow">Local Expert</div>
            <h2>Talk to a Local Tenant Rep</h2>
            <p>
              Connect with a local expert who understands the {{ city.city }} market and can help you evaluate your options.
            </p>

            <div class="expert-panel">
              <h3>{{ city.city }} Tenant Rep</h3>
              <div class="expert-meta">{{ city.city }} · Office &amp; Retail Focus</div>
              <p>
                Work with a local expert who understands the {{ city.city }} market and can help you evaluate options, negotiate terms, and find the right space.
              </p>
              <a class="btn btn-primary" href="#market-contact-form">Get Available Spaces in {{ city.city }}</a>
            </div>

            <p class="subtle-note">
              Interested in becoming a local market expert?
              <a class="building-link" href="/partner-with-rofo/">Partner with Rofo</a>
            </p>
          </div>
        </div>
      </div>

      <div class="city-main-right">
        <div id="market-contact-form" class="city-form city-card">
          <div class="eyebrow">Get help finding space</div>
          <h2>Get Help Finding Space in {{ city.city }}</h2>
          <p>
            Tell us what you’re looking for — we’ll help you find and compare the right spaces in {{ city.city }}.
          </p>
          <p>
            Rofo helps businesses explore and secure commercial space across {{ city.state_abbr }}.
          </p>

          <form
            action="https://formspree.io/f/xreoadbr"
            method="POST"
            class="rofo-formspree-form"
          >
            <input type="hidden" name="source" value="rofo-city-page">
            <input type="hidden" name="page_type" value="city">
            <input type="hidden" name="city" value="{{ city.city }}">
            <input type="hidden" name="state" value="{{ city.state_abbr }}">
            <input type="hidden" name="market" value="{{ city.city }}, {{ city.state_abbr }}">
            <input type="hidden" name="page_url" value="https://www.rofo.com{{ page.url }}">
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none">

            <div class="form-stack">
              <div class="field">
                <label for="lead-name">Name</label>
                <input id="lead-name" name="name" type="text" placeholder="Your name" required>
              </div>
            </div>

            <div class="form-stack">
              <div class="field">
                <label for="lead-email">Email</label>
                <input id="lead-email" name="email" type="email" placeholder="you@example.com" required>
              </div>
            </div>

            <div class="form-stack">
              <div class="field">
                <label for="lead-size">Space size needed <span class="optional">(optional)</span></label>
                <select id="lead-size" name="space_needed">
                  <option value="">Select one</option>
                  <option>Under 1,000 sqft</option>
                  <option>1,000–2,500 sqft</option>
                  <option>2,500–5,000 sqft</option>
                  <option>5,000–10,000 sqft</option>
                  <option>10,000+ sqft</option>
                </select>
              </div>
            </div>

            <div class="form-stack">
              <div class="field">
                <label for="lead-timeline">Timing <span class="optional">(optional)</span></label>
                <select id="lead-timeline" name="timeline">
                  <option value="">Select one</option>
                  <option>ASAP</option>
                  <option>Within 3 months</option>
                  <option>Within 6 months</option>
                  <option>6+ months</option>
                  <option>Just exploring</option>
                </select>
              </div>
            </div>

            <div class="field">
              <label for="lead-notes">What are you looking for? <span class="optional">(optional)</span></label>
              <textarea
                id="lead-notes"
                name="notes"
                placeholder="Example: 3–5 person office, move in June, flexible budget"
              ></textarea>
            </div>

            <div class="btn-row">
              <button class="btn-primary" type="submit">Get Available Spaces</button>
            </div>

            <p class="form-note">✓ No cost • ✓ No obligation • ✓ Local expertise</p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
