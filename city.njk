---
layout: base.njk
pagination:
  data: cities
  size: 1
  alias: city
permalink: "/commercial-real-estate/{{ city.state_abbr }}/{{ city.slug }}/index.html"
eleventyComputed:
  title: >
    {% if city.seo_title %}
      {{ city.seo_title }}
    {% else %}
      Commercial Real Estate in {{ city.city }}, {{ city.state_abbr }} | Office, Retail, Industrial | Rofo
    {% endif %}
  description: >
    {% if city.seo_description %}
      {{ city.seo_description }}
    {% else %}
      Explore office, retail, and industrial space in {{ city.city }}, {{ city.state_abbr }}. Browse representative buildings, compare nearby markets, and get help finding the right space.
    {% endif %}
---
{% set stateName = stateNames[city.state_abbr] or city.state_abbr %}
{% set crumbs = [
  { "label": "Markets", "url": "/markets/" },
  { "label": stateName, "url": "/commercial-real-estate/" + city.state_abbr + "/" },
  { "label": city.city + ", " + city.state_abbr, "url": page.url }
] %}

<style>
  .city-page {
    padding: 8px 0 56px;
  }

  .city-page .city-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .city-page .city-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(340px, 0.95fr);
    gap: 24px;
    align-items: stretch;
    margin-bottom: 24px;
  }

  .city-page .city-main {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(340px, 0.85fr);
    gap: 24px;
    align-items: start;
  }

  .city-page .city-main-left,
  .city-page .city-main-right {
    display: grid;
    gap: 24px;
    min-width: 0;
  }

  .city-page h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.08;
    margin: 0 0 14px;
    color: #0f172a;
  }

  .city-page h2 {
    font-size: 1.55rem;
    line-height: 1.2;
    margin: 0 0 14px;
    color: #0f172a;
  }

  .city-page h3 {
    font-size: 1.08rem;
    margin: 0 0 10px;
    color: #0f172a;
  }

  .city-page p {
    color: #334155;
    line-height: 1.65;
    margin: 0 0 14px;
  }

  .city-page .lead {
    font-size: 1.05rem;
    color: #475569;
    max-width: 62ch;
  }

  .city-page .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
  }

  .city-page .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .city-page .city-stat {
    padding: 18px;
  }

  .city-page .stat-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 8px;
  }

  .city-page .stat-value {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 6px;
    line-height: 1.2;
  }

  .city-page .stat-note {
    color: #64748b;
    font-size: 0.92rem;
    margin: 0;
  }

  .city-page .building-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .city-page .building-card {
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 18px;
    background: #fbfdff;
  }

  .city-page .building-meta {
    color: #64748b;
    font-size: 0.94rem;
    margin-bottom: 10px;
  }

  .city-page .market-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 12px;
  }

  .city-page .market-links a {
    display: inline-flex;
    align-items: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    font-size: 0.93rem;
    white-space: nowrap;
  }

  .city-page .rofo-formspree-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .city-page .field {
    padding: 14px 16px;
  }

  .city-page .form-stack {
    display: block;
  }

  .city-page .form-note {
    margin: 0;
    font-size: 0.92rem;
    color: #64748b;
  }

  .city-page .btn-row {
    display: flex;
    align-items: center;
  }

  .city-page .mini-list {
    margin: 0;
    padding-left: 18px;
    color: #334155;
  }

  .city-page .mini-list li + li {
    margin-top: 8px;
  }

  .city-page .mini-list a {
    text-decoration: none;
  }

  .city-page .mini-list a:hover,
  .subtle-note a:hover {
    text-decoration: underline;
  }

  .subtle-note {
    margin-top: 14px;
    font-size: 13px;
    line-height: 1.5;
    color: #64748b;
  }

  .subtle-note a {
    color: #1346d8;
    text-decoration: none;
    font-weight: 600;
  }

  .city-page .hero-media {
    position: relative;
    height: 100%;
    min-height: 320px;
    border-radius: 14px;
    overflow: hidden;
  }

  .city-page .hero-image {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    display: block;
    border-radius: 14px;
  }

  .city-page .hero-overlay {
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 18px;
    padding: 16px 18px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(226, 232, 240, 0.95);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .city-page .hero-overlay-title {
    margin: 0 0 4px;
    font-size: 1.35rem;
    line-height: 1.15;
    font-weight: 700;
    color: #0f172a;
  }

  .city-page .hero-overlay-meta {
    margin: 0;
    font-size: 0.95rem;
    color: #64748b;
  }

  .city-page .city-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .city-page .city-card--full {
    margin-bottom: 24px;
  }

  .city-page .expert-panel {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 24px;
    background: #f8fafc;
    border: 1px solid #d9e0ea;
    border-radius: 18px;
  }

  .city-page .expert-panel h3,
  .city-page .expert-panel p,
  .city-page .expert-meta {
    margin: 0;
  }

  .city-page .expert-meta {
    color: #64748b;
    font-size: 0.95rem;
  }

  .city-page .expert-panel .btn {
    margin-top: 4px;
    align-self: flex-start;
  }

  .city-page .featured-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 12px;
  }

  .city-page .featured-header__cta {
    flex: 0 0 auto;
    text-align: right;
    font-size: 13px;
    line-height: 1.4;
    color: #64748b;
    white-space: nowrap;
  }

  .city-page .featured-header__cta a {
    display: block;
    font-weight: 600;
  }

  .building-card-compact {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 16px;
  padding: 14px;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  background: #ffffff;
  transition: box-shadow 0.15s ease, transform 0.15s ease;
}

.building-card-compact:hover {
  box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
  transform: translateY(-1px);
}

  .building-card-compact__image {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 10px;
    background: #f8fafc;
  }

  .building-card-compact__content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .building-card-compact__title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .building-card-compact__title a {
    text-decoration: none;
  }

  .building-card-compact__meta {
    margin: 0;
    font-size: 0.9rem;
    color: #64748b;
  }

  .building-card-compact__address {
    margin: 0;
    font-size: 0.9rem;
    color: #334155;
  }

  .building-card-compact__teaser {
    grid-column: 1 / -1;
    margin: 6px 0 0;
    color: #334155;
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .building-card-compact__cta {
    grid-column: 1 / -1;
    margin: 4px 0 0;
    font-weight: 600;
  }

  .building-card-compact__cta a {
    text-decoration: none;
  }

  @media (max-width: 980px) {
    .city-page .city-main,
    .city-page .city-hero {
      grid-template-columns: 1fr;
    }

    .city-page .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .building-card-compact {
      grid-template-columns: 80px 1fr;
    }

    .city-page .stats-grid,
    .city-page .building-grid {
      grid-template-columns: 1fr;
    }
  @media (max-width: 980px) {
  .city-page .building-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
    .city-page .city-shell {
      padding: 0 16px;
    }

    .city-page .featured-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .city-page .featured-header__cta {
      text-align: left;
      white-space: normal;
    }
  }
</style>

<section class="city-page">
  <div class="city-shell">
    {% include "partials/breadcrumbs.njk" %}

    <div class="city-hero">
      <div class="city-card">
        <div class="eyebrow">Market</div>
        <h1>Commercial Real Estate in {{ city.city }}, {{ city.state_abbr }}</h1>
        <p class="lead">
          Explore commercial real estate in {{ city.city }}, {{ city.state_abbr }} — including office, retail, and flexible workspace options. Browse representative buildings, compare nearby markets, and get help finding the right space.
        </p>
        <p class="subtle-note">
          Rofo helps businesses explore commercial real estate markets across the U.S. with curated data and local expertise.
        </p>

        {% include "partials/space-type/pill-nav.njk" %}
      </div>

      <div class="city-sidecard">
        <div class="hero-media">
          <img
            class="hero-image"
            src="/images/placeholders/city-placeholder.svg"
            alt="{{ city.city }}, {{ city.state_abbr }}"
          />
          <div class="hero-overlay">
            <p class="hero-overlay-title">{{ city.city }}, {{ city.state_abbr }}</p>
            <p class="hero-overlay-meta">Commercial Real Estate Market</p>
          </div>
        </div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="city-stat">
        <div class="stat-label">Market</div>
        <div class="stat-value">{{ city.city }}</div>
        <p class="stat-note">{{ city.state_abbr }}</p>
      </div>

      <div class="city-stat">
        <div class="stat-label">Buildings</div>
        <div class="stat-value">{{ city.building_count or "—" }}</div>
        <p class="stat-note">Known buildings in this market</p>
      </div>

      <div class="city-stat">
        <div class="stat-label">County</div>
        <div class="stat-value">{{ city.county or "—" }}</div>
        <p class="stat-note">Local market context</p>
      </div>

      <div class="city-stat">
        <div class="stat-label">Coordinates</div>
        <div class="stat-value">{% if city.lat and city.lng %}{{ city.lat }}, {{ city.lng }}{% else %}—{% endif %}</div>
        <p class="stat-note">Reference location</p>
      </div>
    </div>

    <div class="city-card city-card--full">
      <div class="featured-header">
        <div>
          <div class="eyebrow">Featured</div>
          <h2>Representative Buildings in {{ city.city }}</h2>
        </div>

        <div class="featured-header__cta">
          <span>Want your building featured?</span>
          <a class="building-link" href="/partner-with-rofo/">Partner with Rofo</a>
        </div>
      </div>

      <p>
        Explore a selection of office and flexible workspace locations across {{ city.city }}. These buildings represent the types of spaces commonly available in this market.
      </p>

      {% set featuredBuildings = [] %}
      {% for b in sampleBuildings %}
        {% if b.city == city.city and b.state_abbr == city.state_abbr %}
          {% set featuredBuildings = (featuredBuildings.push(b), featuredBuildings) %}
        {% endif %}
      {% endfor %}

      <div class="building-grid">
        {% for b in featuredBuildings.slice(0, 6) %}
          {% set building = b %}
          {% include "partials/shared/building-card-compact.njk" %}
        {% endfor %}
      </div>

      <p style="margin-top: 16px;">
        <a class="btn-secondary" href="/commercial-real-estate/{{ city.state_abbr }}/{{ city.slug }}/buildings/">
          Browse all buildings in {{ city.city }} →
        </a>
      </p>
    </div>

    <div class="city-main">
      <div class="city-main-left">
        <div class="city-card">
          <div class="eyebrow">Overview</div>
          <h2>Explore the {{ city.city }} market</h2>
          <p>
            Rofo helps businesses research commercial real estate in {{ city.city }}, {{ city.state_abbr }}.
            Use this page as a starting point to understand the market, explore representative buildings, and narrow your search.
          </p>
          <p>
            Whether you are looking for office space, retail frontage, or industrial property,
            Rofo is designed to make market discovery simpler and more efficient.
          </p>
        </div>

        <div class="city-grid">
          <div class="city-card seo-copy">
            <div class="eyebrow">About This Market</div>
            <h2>About commercial real estate in {{ city.city }}</h2>
            <p>
              {{ city.city }}, {{ city.state_abbr }} offers a mix of office, retail, and industrial real estate options for businesses at different stages of growth.
              Whether you are evaluating a first location, relocating, or expanding, this market can offer a range of property types and leasing options.
            </p>
            <p>
              Businesses often compare areas based on accessibility, surrounding amenities, workforce, and proximity to customers or logistics corridors.
              Rofo helps simplify that search by making it easier to explore buildings, compare nearby markets, and connect with help when you need it.
            </p>
            <p>
              Use this page to get a practical overview of the {{ city.city }} market, review featured properties, and expand your search into nearby cities if you want a wider set of options.
            </p>
          </div>

          <div class="city-card">
            <div class="eyebrow">Market Context</div>
            <h2>{{ city.market_context_heading }}</h2>
            <p>{{ city.market_context_paragraph1 }}</p>
            <p>{{ city.market_context_paragraph2 }}</p>
          </div>

          <div class="city-card">
            <div class="eyebrow">Nearby Markets</div>
            <h2>Explore nearby cities</h2>
            <p>Browse nearby markets to expand your search.</p>

            <div class="market-links">
              {% if city.nearby_city_details and city.nearby_city_details.length %}
                {% for nearby in city.nearby_city_details %}
                  {% set nearbyCity = cityLookup[nearby.slug] %}
                  {% if nearbyCity %}
                    <a href="{{ nearbyCity.path }}">{{ nearbyCity.label }} · {{ nearby.distance_miles }} mi</a>
                  {% endif %}
                {% endfor %}
              {% else %}
                <span class="subtle-note">Nearby markets will appear here as city coverage expands.</span>
              {% endif %}
            </div>
          </div>

          <div class="city-card">
            <div class="eyebrow">Resources</div>
            <h2>Helpful Resources for Businesses in {{ city.city }}</h2>
            <p>Learn more about leasing, pricing, and how to evaluate commercial space in {{ city.city }}.</p>
            <ul class="mini-list">
              <li>
                <a href="/blog/typical-lease-rates-in-{{ city.slug }}/">
                  Typical Lease Rates in {{ city.city }}
                </a>
              </li>
              <li>
                <a href="/blog/best-neighborhoods-for-office-space-in-{{ city.slug }}/">
                  Best Neighborhoods for Office Space in {{ city.city }}
                </a>
              </li>
              <li>
                <a href="/blog/how-to-evaluate-office-space-to-lease/">
                  How to Evaluate Office Space Before You Lease
                </a>
              </li>
            </ul>
          </div>

          <div class="city-card">
            <div class="eyebrow">Local Expert</div>
            <h2>Talk to a Local Tenant Rep</h2>
            <p>
              Connect with a local expert who understands the {{ city.city }} market and can help you evaluate your options.
            </p>

            <div class="expert-panel">
              <h3>{{ city.city }} Tenant Rep</h3>
              <div class="expert-meta">{{ city.city }} · Office &amp; Retail Focus</div>
              <p>
                Work with a local expert who understands the {{ city.city }} market and can help you evaluate options, negotiate terms, and find the right space.
              </p>
              <a class="btn btn-primary" href="#market-contact-form">Get Free Help Finding Space</a>
            </div>

            <p class="subtle-note">
              Interested in becoming a local market expert?
              <a class="building-link" href="/partner-with-rofo/">Partner with Rofo</a>
            </p>
          </div>
        </div>
      </div>

      <div class="city-main-right">
        <div id="market-contact-form" class="city-form city-card">
          <div class="eyebrow">Get help finding space</div>
          <h2>Get Free Help Finding Space in {{ city.city }}</h2>
          <p>Tell us what you’re looking for and we’ll send you relevant options in {{ city.city }}.</p>

          <form
            action="https://formspree.io/f/xreoadbr"
            method="POST"
            class="rofo-formspree-form"
          >
            <input type="hidden" name="source" value="rofo-city-page">
            <input type="hidden" name="page_type" value="city">
            <input type="hidden" name="city" value="{{ city.city }}">
            <input type="hidden" name="state" value="{{ city.state_abbr }}">
            <input type="hidden" name="market" value="{{ city.city }}, {{ city.state_abbr }}">
            <input type="hidden" name="page_url" value="https://www.rofo.com{{ page.url }}">
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none">

            <div class="form-stack">
              <div class="field">
                <label for="lead-name">Name</label>
                <input id="lead-name" name="name" type="text" placeholder="Your name" required>
              </div>
            </div>

            <div class="form-stack">
              <div class="field">
                <label for="lead-email">Email</label>
                <input id="lead-email" name="email" type="email" placeholder="you@example.com" required>
              </div>
            </div>

            <div class="form-stack">
              <div class="field">
                <label for="lead-size">Space needed <span class="optional">(optional)</span></label>
                <select id="lead-size" name="space_needed">
                  <option value="">Select one</option>
                  <option>Under 1,000 sqft</option>
                  <option>1,000–2,500 sqft</option>
                  <option>2,500–5,000 sqft</option>
                  <option>5,000–10,000 sqft</option>
                  <option>10,000+ sqft</option>
                </select>
              </div>
            </div>

            <div class="form-stack">
              <div class="field">
                <label for="lead-timeline">Timeline <span class="optional">(optional)</span></label>
                <select id="lead-timeline" name="timeline">
                  <option value="">Select one</option>
                  <option>ASAP</option>
                  <option>Within 3 months</option>
                  <option>Within 6 months</option>
                  <option>6+ months</option>
                  <option>Just exploring</option>
                </select>
              </div>
            </div>

            <div class="field">
              <label for="lead-notes">What kind of space are you looking for? <span class="optional">(optional)</span></label>
              <textarea
                id="lead-notes"
                name="notes"
                placeholder="Business type, preferred area, must-haves..."
              ></textarea>
            </div>

            <div class="btn-row">
              <button class="btn-primary" type="submit">Get Free Help Finding Space</button>
            </div>

            <p class="form-note">✓ No cost • ✓ No obligation • ✓ Fast response</p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>