---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <url>
    <loc>https://rofo.com/</loc>
  </url>

  <url>
    <loc>https://rofo.com/markets/</loc>
  </url>

  {% for city in cities %}
  <url>
    <loc>https://rofo.com{{ city.path }}</loc>
  </url>
  {% endfor %}

  {% for building in buildings %}
  <url>
    <loc>https://rofo.com/commercial-real-estate/{{ building.state_abbr }}/{{ building.city_slug }}/buildings/{{ building.building_slug }}/</loc>
  </url>
  {% endfor %}

  {% for company in companies %}
  <url>
    <loc>https://rofo.com/commercial-real-estate/company/{{ company.slug }}/</loc>
  </url>
  {% endfor %}

</urlset>