---
layout: base.njk
pagination:
  data: spaceTypePages
  size: 1
  alias: entry
permalink: "/commercial-real-estate/{{ entry.state }}/{{ entry.city_slug }}/{{ entry.page_slug }}/index.html"
eleventyComputed:
  title: "{{ entry.spaceType.label }} Space in {{ entry.city.city }}, {{ entry.city.state_abbr }} | Commercial Real Estate | Rofo"
  description: "Explore {{ entry.spaceType.label | lower }} space in {{ entry.city.city }}, {{ entry.city.state_abbr }}. Browse representative buildings and get help finding the right commercial space."
---

{% set city = entry.city %}
{% set spaceType = entry.spaceType %}
{% set representativeBuildings = entry.representativeBuildings %}
{% set crumbs = [
  { "label": city.city + ", " + city.state_abbr, "url": "/commercial-real-estate/" + (city.state_abbr | lower) + "/" + (city.slug | lower) + "/" },
  { "label": spaceType.pluralLabel, "url": "/commercial-real-estate/" + (city.state_abbr | lower) + "/" + (city.slug | lower) + "/" + spaceType.slug + "/" }
] %}

<section class="market-page market-page--space-type">
  <div class="city-shell">
    {% include "partials/breadcrumbs.njk" %}
    {% include "partials/space-type/hero.njk" %}

    <div class="page-stack">
      {% include "partials/space-type/market-snapshot.njk" %}
      {% include "partials/space-type/guide-card.njk" %}

      {% include "partials/space-type/definitions-card.njk" %}
      {% include "partials/space-type/budget-card.njk" %}
      {% include "partials/space-type/timeline-card.njk" %}

      {% include "partials/space-type/representative-buildings.njk" %}
      {% include "partials/space-type/nearby-markets.njk" %}
      {% include "partials/space-type/related-space-types.njk" %}
    </div>
  </div>
</section>